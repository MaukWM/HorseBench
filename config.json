{
  "benchmark": "AAAAAAAABench",
  "version": "0.1",
  "collect": {
    "prompts_file": "prompts.json",
    "models": [
      "openai/gpt-5-mini"
    ],
    "categories": [],
    "num_runs": 1,
    "parallelism": 8,
    "max_inflight_per_model": 2,
    "temperature": null,
    "max_tokens": 4096,
    "shuffle_tasks": true,
    "rate_limit_cooldown_seconds": 20.0,
    "checkpoint_fsync_every": 10
  },
  "detection": {
    "borderline_ratio": 0.5
  },
  "output": {
    "responses_file": "responses.jsonl",
    "summary_file": "summary.json",
    "run_dir": "data/runs"
  }
}
