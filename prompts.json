{
  "benchmark": "AAAAAAAABench",
  "version": "0.1",
  "description": "Prompts designed to test if LLMs get stuck in repetitive A generation loops",
  "categories": [
    {
      "category": "echo_trap",
      "description": "Prompts containing many A's to see if model continues the pattern",
      "prompts": [
        {
          "id": "echo_1000a",
          "prompt": "",
          "description": "1000+ A's as the entire prompt"
        },
        {
          "id": "echo_5000a",
          "prompt": "",
          "description": "5000+ A's as the entire prompt"
        },
        {
          "id": "echo_10000a",
          "prompt": "",
          "description": "10000+ A's as the entire prompt"
        }
      ]
    },
    {
      "category": "direct_request",
      "description": "Explicitly asking the model to generate a long string",
      "prompts": [
        {
          "id": "direct_1k",
          "prompt": "give me a string of length 1000. actually produce it yourself don't write code.",
          "description": "Direct request for string length 1000"
        },
        {
          "id": "direct_2k",
          "prompt": "give me a string of length 2000. actually produce it yourself don't write code.",
          "description": "Direct request for string length 2000"
        },
        {
          "id": "direct_5k",
          "prompt": "give me a string of length 5000. actually produce it yourself don't write code.",
          "description": "Direct request for string length 5000"
        },
        {
          "id": "direct_10k",
          "prompt": "give me a string of length 10000. actually produce it yourself don't write code.",
          "description": "Direct request for string length 10000"
        }
      ]
    }
  ]
}
